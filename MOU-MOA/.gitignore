/vendor
/.phpunit.cache
/.phpunit.result.cache
/.phpactor.json
/auth.json
/Homestead.json
/Homestead.yaml

# Node / build outputs (Laravel Vite + Inertia tooling)
/node_modules
/public/build
/public/hot
/public/storage
/public/fonts-manifest.dev.json
/bootstrap/ssr

# Local data & uploads
/storage/*.key
/storage/pail
/database/database.sqlite

# Vite-generated assets are not committed
/resources/js/actions
/resources/js/routes
/resources/js/wayfinder

# Vite TypeScript build info
/tsconfig.tsbuildinfo
